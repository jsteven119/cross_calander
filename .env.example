# Google Sheets API (서비스 계정 JSON 키 내용을 Base64 인코딩)
GOOGLE_SERVICE_ACCOUNT_KEY=your_base64_encoded_service_account_json

# Google Sheet ID (URL에서 /spreadsheets/d/{ID}/edit 부분)
GOOGLE_SHEET_ID=your_sheet_id_here

# 시트 이름 (기본값: Sheet1)
GOOGLE_SHEET_NAME=2026 플래너

# Apps Script → Next.js 웹훅 인증 토큰 (임의 문자열 설정)
REFRESH_SECRET=your_secret_token_here

# 앱 URL (Vercel 배포 후 변경)
NEXT_PUBLIC_APP_URL=http://localhost:3000
